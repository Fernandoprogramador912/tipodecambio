# Puerto del servidor backend (por defecto 3000)
PORT=3000

# --- USD "mayorista" = Últ encabezado "Dólar USA" en A3 (DLR/SPOT), no DLR/MAY26 ---
# WebSocket Matriz (misma fuente que matbarofex.primary.ventures)
# A3_MATRIZ_WS_URL=wss://matbarofex.primary.ventures/ws
# A3_MD_TOPIC=md.rx_DDF_DLR_SPOT
# A3_MAYORISTA_SYMBOL=DLR/SPOT
# Reconexión automática si el WS de A3 deja de enviar datos (como refrescar la web de A3)
# A3_WS_STALE_MS=90000
# A3_WS_MAX_SESSION_MS=1200000
# PRIMARY_WS_STALE_MS=90000

# Primary/reMarkets (bid/ask complementario; futuros para proyección)
# FUTURES_BASE_URL=https://api.remarkets.primary.com.ar
# FUTURES_USER=
# FUTURES_PASSWORD=

# Requerido para cotización USD y proyección
ENABLE_FUTURES=true

# Cruces internacionales (EUR/USD, USD/BRL, etc.): Yahoo Finance en vivo (sin key).
# Si Yahoo falla, fallback automático a Frankfurter (BCE, referencia diaria).

# Supabase (proyecciones diarias persistentes)
# SUPABASE_URL=https://tu-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DAILY_PROJECTIONS_TABLE=daily_projections
# SUPABASE_TC_INTRADAY_TABLE=tc_intraday_days
# TC_HISTORY_START_DATE=2026-05-20

# Secreto compartido entre Render y GitHub Actions para ejecutar /api/projection/daily-run
# PROJECTION_JOB_SECRET=

# Producción sin PC: ver DEPLOY.md (Render free + keep-alive, u Oracle Cloud gratis).
# HOST=0.0.0.0 está por defecto en Docker; PORT lo asigna el hosting.
